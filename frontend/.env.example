# Vite frontend env vars (must start with VITE_)

# Backend API base URL. Leave empty/unset for local dev (Vite's proxy in
# vite.config.js forwards /api to http://localhost:5000 automatically).
# REQUIRED on Vercel/production - set to your deployed backend URL, e.g.:
# VITE_API_URL=https://medcare-1tmn.onrender.com
VITE_API_URL=

# Leave empty to use mock Google login for local dev/testing
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
